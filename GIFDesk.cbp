<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="GIFDesk" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/GIFDesk" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-march=i386" />
					<Add option="-std=c99" />
					<Add option="-m32" />
				</Compiler>
				<Linker>
					<Add option="-static" />
					<Add option="-m32" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/GIFDesk" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-march=i386" />
					<Add option="-flto" />
					<Add option="-Wall" />
					<Add option="-std=c99" />
					<Add option="-m32" />
					<Add option="-ffunction-sections -Wl,--gc-sections -fno-asynchronous-unwind-tables -Wl,--strip-all" />
				</Compiler>
				<Linker>
					<Add option="-flto" />
					<Add option="-s" />
					<Add option="-static" />
					<Add option="-m32" />
				</Linker>
			</Target>
		</Build>
		<Linker>
			<Add library="gdi32" />
			<Add library="user32" />
			<Add library="kernel32" />
			<Add library="comctl32" />
			<Add library="opengl32" />
			<Add library="comdlg32" />
			<Add library="libgif/libgif.a" />
			<Add library="libapng/libapng.a" />
			<Add library="libapng/zlib.a" />
			<Add library="libwebp/libwebp.a" />
		</Linker>
		<Unit filename="data.h" />
		<Unit filename="flags.h" />
		<Unit filename="fonts.h" />
		<Unit filename="gifdesk.h" />
		<Unit filename="handlers.h" />
		<Unit filename="languages.h" />
		<Unit filename="libapng/png.h" />
		<Unit filename="libapng/pngconf.h" />
		<Unit filename="libapng/pnglibconf.h" />
		<Unit filename="libgif/gif_lib.h" />
		<Unit filename="libwebp/decode.h" />
		<Unit filename="libwebp/demux.h" />
		<Unit filename="libwebp/encode.h" />
		<Unit filename="libwebp/format_constants.h" />
		<Unit filename="libwebp/mux.h" />
		<Unit filename="libwebp/mux_types.h" />
		<Unit filename="libwebp/types.h" />
		<Unit filename="main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="manager.h" />
		<Unit filename="render.h" />
		<Unit filename="resource.rc">
			<Option compilerVar="WINDRES" />
		</Unit>
		<Unit filename="settings.h" />
		<Unit filename="types.h" />
		<Extensions />
	</Project>
</CodeBlocks_project_file>
